# ─────────────────────────────────────────────────────────────────────────────
# YoJaz Elite — Stripe Backend Environment Variables
# Copy this file to server/.env and fill in your values.
# NEVER commit server/.env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Stripe secret key (starts with sk_test_ or sk_live_)
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Stripe webhook signing secret (starts with whsec_)
# Found at: https://dashboard.stripe.com/webhooks  (after creating the webhook)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs for each plan
# Create these at: https://dashboard.stripe.com/products
# Each product needs a recurring monthly price — copy the price ID (starts with price_)
STRIPE_PRICE_BASIC=prod_UZY0yrv2v9ZuFU
STRIPE_PRICE_PREMIUM=prod_UZY04tpIvwiPAR
STRIPE_PRICE_EXTREME=prod_UZY1EV2R7DAclE

# Your frontend URL (no trailing slash)
CLIENT_URL=https://yojaz-elite-8iwbtepxm-jahwick399-lgtms-projects.vercel.app

# Port for this backend server
PORT=3001
